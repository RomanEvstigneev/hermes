{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Hermes",
    "description": "Your Hermes agent on Slack",
    "background_color": "#1a1a2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Hermes",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Chat with Hermes in threads and DMs."
    },
    "slash_commands": [
      { "command": "/hermes", "description": "Talk to Hermes or run a subcommand", "usage_hint": "[subcommand] [args]" },
      { "command": "/new", "description": "Start a new session" },
      { "command": "/retry", "description": "Retry the last message" },
      { "command": "/undo", "description": "Remove the last exchange" },
      { "command": "/title", "description": "Set a title for current session", "usage_hint": "[name]" },
      { "command": "/branch", "description": "Branch the current session", "usage_hint": "[name]" },
      { "command": "/compress", "description": "Compress conversation context", "usage_hint": "[topic]" },
      { "command": "/rollback", "description": "List or restore checkpoints", "usage_hint": "[number]" },
      { "command": "/stop", "description": "Kill all background processes" },
      { "command": "/approve", "description": "Approve a pending command", "usage_hint": "[session|always]" },
      { "command": "/deny", "description": "Deny a pending command" },
      { "command": "/background", "description": "Run a prompt in the background", "usage_hint": "<prompt>" },
      { "command": "/agents", "description": "Show active agents and tasks" },
      { "command": "/queue", "description": "Queue a prompt for next turn", "usage_hint": "<prompt>" },
      { "command": "/steer", "description": "Inject a message after tool call", "usage_hint": "<prompt>" },
      { "command": "/status", "description": "Show session info" },
      { "command": "/profile", "description": "Show active profile" },
      { "command": "/sethome", "description": "Set this chat as home channel" },
      { "command": "/resume", "description": "Resume a previous session", "usage_hint": "[name]" },
      { "command": "/model", "description": "Switch model for this session", "usage_hint": "[model]" },
      { "command": "/personality", "description": "Set a personality", "usage_hint": "[name]" },
      { "command": "/footer", "description": "Toggle metadata footer", "usage_hint": "[on|off]" },
      { "command": "/yolo", "description": "Skip all command approvals" },
      { "command": "/reasoning", "description": "Manage reasoning display", "usage_hint": "[level]" },
      { "command": "/fast", "description": "Toggle fast mode", "usage_hint": "[normal|fast]" },
      { "command": "/voice", "description": "Toggle voice mode", "usage_hint": "[on|off]" },
      { "command": "/curator", "description": "Skill maintenance", "usage_hint": "[subcommand]" },
      { "command": "/reloadmcp", "description": "Reload MCP servers" },
      { "command": "/reloadskills", "description": "Re-scan skills directory" },
      { "command": "/commands", "description": "Browse all commands", "usage_hint": "[page]" },
      { "command": "/help", "description": "Show available commands" },
      { "command": "/restart", "description": "Restart the gateway" },
      { "command": "/usage", "description": "Show token usage" },
      { "command": "/insights", "description": "Show analytics", "usage_hint": "[days]" },
      { "command": "/update", "description": "Update Hermes to latest" },
      { "command": "/debug", "description": "Upload debug report" },
      { "command": "/reset", "description": "Alias for new" },
      { "command": "/fork", "description": "Alias for branch", "usage_hint": "[name]" },
      { "command": "/bg", "description": "Alias for background", "usage_hint": "<prompt>" },
      { "command": "/btw", "description": "Alias for background", "usage_hint": "<prompt>" },
      { "command": "/tasks", "description": "Alias for agents" },
      { "command": "/q", "description": "Alias for queue", "usage_hint": "<prompt>" },
      { "command": "/provider", "description": "Alias for model", "usage_hint": "[model]" }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "files:read",
        "files:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
